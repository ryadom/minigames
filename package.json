{
  "name": "minigames",
  "version": "1.0.0",
  "description": "A collection of free browser minigames.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts && SERVE_ROOT=dist bun scripts/serve.mjs",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "bun scripts/validate.mjs",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "bun-types": "^1.3.14",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3"
  }
}
